# Crown-App chain config. Copy to .env.local and fill in as the backend ships.
# Everything has a sane devnet default baked into lib/chain/config.ts — you only
# need this file to OVERRIDE ids or to light up the ICP features.

# ── Solana devnet (deployed today; defaults already point at these) ─────────
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# NEXT_PUBLIC_SPLITTER=DDSeyx684iU9agHbXExwS3NstLvQeLKZcJWcJFSh1VDA
# NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# NEXT_PUBLIC_FACTORY_TWO_OUTCOME=83f7ziVs5VeQ8xiDka8zczbfJT4WcxsXQ18cqWwmV5ur
# NEXT_PUBLIC_FACTORY_PAYOUT_TABLE=EzvxRLxLvPW6TdmVCQ2JBWiv37tCD6kSngNvS2z2D3ka
# NEXT_PUBLIC_FACTORY_STREAM=57MpCQ3TfAE66qDAnfkP9AX7LRqwd4CNX8uN6DaVwm3V
# NEXT_PUBLIC_FEE_WALLET=3it64t7KXNip1C1BRYNh8ygeKyujWnaQrPSj3hV9TWbE

# ── ICP (NOT deployed yet — reputation & games stay on mock until these are set) ──
# Ask the backend dev for the gateway host + canister principals, then uncomment:
# NEXT_PUBLIC_IC_HOST=https://icp0.io
# NEXT_PUBLIC_CROWN_INDEX_PRINCIPAL=
# NEXT_PUBLIC_TASKS_PRINCIPAL=
# NEXT_PUBLIC_FUNDING_PRINCIPAL=
# NEXT_PUBLIC_AUCTION_PRINCIPAL=
# NEXT_PUBLIC_SUBSCRIPTION_PRINCIPAL=

# ── Release knobs ───────────────────────────────────────────────────────────
# Fresh visitors see real chain data instead of the mock demo:
# NEXT_PUBLIC_DEFAULT_MODE=chain

# ── Database ────────────────────────────────────────────────────────────────
# Default: SQLite file at data/crown.db (daily backups in data/backups/).
# For serverless hosting point at a Turso/libsql server instead:
# LIBSQL_URL=libsql://<your-db>.turso.io
# LIBSQL_AUTH_TOKEN=
# Override the local DB directory (e.g. a mounted volume):
# CROWN_DB_DIR=/var/lib/crown
